<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- App-owned services must use HTTPS. -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- Some school educational systems still expose WebView pages over HTTP. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">edu.cn</domain>
    </domain-config>
</network-security-config>
